# ── Where the main bot's webhook server is reachable ────────────────────────
# Your XWALLET dashboard's public URL (the watcher posts to {this}/webhooks/watcher)
MAIN_BOT_URL=https://yourapp.onrender.com

# ── Shared secret ────────────────────────────────────────────────────────────
# Must match WATCHER_SHARED_SECRET in the main bot's .env exactly.
# Generate one with: openssl rand -hex 32
SHARED_SECRET=

# ── Shared deposit addresses (leave blank to skip a coin) ──────────────────
BTC_ADDRESS=
LTC_ADDRESS=
ETH_ADDRESS=
SOL_ADDRESS=
USDT_ERC20_ADDRESS=
USDT_TRC20_ADDRESS=

# ── ETH + USDT-ERC20 watchers need a free key from etherscan.io/apis ───────
ETHERSCAN_API_KEY=

# ── USDT-TRC20 watcher: optional free key from trongrid.io (raises limits) ─
TRONGRID_API_KEY=

# ── Polling frequency in seconds ────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30
