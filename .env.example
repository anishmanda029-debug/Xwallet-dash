# ════════════════════════════════════════════════════════════════════
#  XWALLET — Railway Environment Variables
#  Add these in Railway → Project → Variables
# ════════════════════════════════════════════════════════════════════

# ── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
BOT_PREFIX=$

# ── Owner & Staff ─────────────────────────────────────────────────────────────
OWNER_ID=your_discord_user_id
OWNER_PASSWORD=strong_password_here
OWNER_ID_1=your_discord_user_id
OWNER_ID_2=second_owner_id
DEV_ID_1=dev_id_1
DEV_ID_2=dev_id_2

# ── Guild ─────────────────────────────────────────────────────────────────────
HOME_GUILD_ID=your_server_id
DEV_GUILD_ID=your_server_id

# ── Database (Railway provides this automatically when you add PostgreSQL) ────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── HD Wallet (Trust Wallet Recovery Phrase) ──────────────────────────────────
WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ── Deposit Credit Delay ──────────────────────────────────────────────────────
DEPOSIT_CREDIT_DELAY_MINUTES=15

# ── Fees ──────────────────────────────────────────────────────────────────────
FEE_PCT=2
MIN_USD=0.03

# ── Network Fees (shown on deposit invoice) ───────────────────────────────────
BTC_NETWORK_FEE=0.0001
LTC_NETWORK_FEE=0.001
ETH_NETWORK_FEE=0.002
SOL_NETWORK_FEE=0.000005
USDTERC20_NETWORK_FEE=0.003
USDTTRC20_NETWORK_FEE=1.0

# ── Watcher ───────────────────────────────────────────────────────────────────
WATCHER_SHARED_SECRET=generate_with_openssl_rand_hex_32
MAIN_BOT_URL=https://your-railway-app.up.railway.app
POLL_INTERVAL_SECONDS=30

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_SECRET=random_long_secret_string
PORT=5000
FLASK_DEBUG=false

# ── Discord OAuth2 (for Dashboard login) ──────────────────────────────────────
DISCORD_CLIENT_ID=your_oauth2_client_id
DISCORD_CLIENT_SECRET=your_oauth2_client_secret
DISCORD_REDIRECT_URI=https://your-railway-app.up.railway.app/callback

# ── Network ───────────────────────────────────────────────────────────────────
NETWORK=mainnet

# ── Alchemy (optional — ETH deposit detection) ────────────────────────────────
ALCHEMY_API_KEY=
ALCHEMY_SIGNING_KEY=

# ── Auto-Withdraw Limits ──────────────────────────────────────────────────────
AUTO_WITHDRAW_MAX_TX_USD=200
AUTO_WITHDRAW_DAILY_LIMIT_USD=500
